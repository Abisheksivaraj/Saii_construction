{
  "name": "saiiconstruction",
  "version": "1.0.0",
  "description": "SaiiConstruction Full Stack App",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "concurrently --raw \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && npm run dev",
    "frontend": "cd frontend && npx expo start -c",
    "start": "npm run dev",
    "clean": "npm run clean:frontend && npm run clean:backend",
    "clean:frontend": "cd frontend && rm -rf node_modules .expo && npm install",
    "clean:backend": "cd backend && rm -rf node_modules && npm install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
